# Newsletter AI v0.2 configuration example
# Copy to .env and adjust as needed (never commit .env)

NEWSLETTER_BASE_DIR=/path/to/your/newsletter-ai
NEWSLETTER_TZ=Asia/Shanghai
NEWSLETTER_OUTPUT_DIR=output
NEWSLETTER_DATA_DIR=data

# Telegram (optional, only if publishing)
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here